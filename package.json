{
  "name": "breast-cancer-staging",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "expo": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist && node scripts/prepare-pwa.mjs",
    "build:github-pages": "npm run build:web && node scripts/prepare-github-pages.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:node && npm run test:react",
    "test:verbose": "tsc -p tsconfig.test.json && node .test-build/src/domain/staging.test.js",
    "test:node": "tsc -p tsconfig.test.json && node --test .test-build/src/**/*.test.js",
    "test:react": "jest --runInBand"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/*.rn-test.tsx"
    ]
  }
}
